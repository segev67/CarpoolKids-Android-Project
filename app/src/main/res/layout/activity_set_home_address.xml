<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true"
    android:padding="@dimen/spacing_section">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/set_home_address_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section"
            android:gravity="center"
            android:text="@string/set_home_address_title"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="@dimen/text_title_size"
            android:textStyle="bold" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/set_home_address_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="@string/set_home_address_explanation"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="@dimen/text_section_label_size" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/set_home_address_set_button"
            style="@style/Widget.CarpoolKids.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section_lg"
            android:text="@string/set_home_address_set_button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/set_home_address_skip_button"
            style="@style/Widget.CarpoolKids.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/set_home_address_skip_button" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/set_home_address_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>
</ScrollView>
