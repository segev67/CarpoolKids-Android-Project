<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="@dimen/spacing_section">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Group name: "Carpool: <group name>" -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_group_name"
            style="@style/TextAppearance.Dashboard.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Carpool: Group name"
            tools:visibility="visible" />

        <!-- Hello <user name> -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_hello_user"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:visibility="gone"
            app:layout_goneMarginTop="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_group_name"
            tools:text="Hello Jane"
            tools:visibility="visible" />

        <!-- Home address banner (Phase 2): visible when the user has no home coordinates yet. -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dashboard_home_home_address_banner"
            style="@style/Widget.CarpoolKids.CardView.Dashboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_hello_user"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/dashboard_home_home_address_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:text="@string/profile_home_section_title"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="@dimen/text_section_label_size"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_home_address_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:text="@string/profile_home_banner_text"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="@dimen/text_section_label_size" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/dashboard_home_home_address_action"
                        style="@style/Widget.CarpoolKids.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_home_banner_action"
                        android:textSize="@dimen/text_button_compact" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Today's Training section -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_today_label"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/home_todays_training"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_home_address_banner"
            app:layout_goneMarginTop="@dimen/spacing_md" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dashboard_home_today_card"
            style="@style/Widget.CarpoolKids.CardView.Dashboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_today_label"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_today_team_name"
                        style="@style/TextAppearance.Home.TeamName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        tools:text="Group name" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/dashboard_home_today_badge"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_badge_size"
                        app:chipBackgroundColor="@color/dashboard_primary"
                        app:chipMinHeight="24dp"
                        tools:text="Type" />
                </LinearLayout>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/dashboard_home_today_date"
                    style="@style/TextAppearance.Dashboard.SectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/dashboard_primary"
                    tools:text="Date" />
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/dashboard_home_today_time"
                    style="@style/TextAppearance.Home.TeamName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    tools:text="Time range" />
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/dashboard_home_today_location"
                    style="@style/TextAppearance.Dashboard.SectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="Location" />
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/dashboard_home_today_address"
                    style="@style/TextAppearance.Dashboard.SectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:visibility="gone"
                    tools:text="Address"
                    tools:visibility="visible" />
                <LinearLayout
                    android:id="@+id/dashboard_home_today_driver_to_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_today_to_label"
                        style="@style/TextAppearance.Dashboard.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_today_driver_to"
                        style="@style/TextAppearance.Dashboard.SectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/dashboard_primary"
                        tools:text="Driver" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/dashboard_home_today_driver_back_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_today_from_label"
                        style="@style/TextAppearance.Dashboard.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/dashboard_home_today_driver_back"
                        style="@style/TextAppearance.Dashboard.SectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/dashboard_primary"
                        tools:text="Driver" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Shown when there is no training today -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_no_training_message"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="@string/home_today_day_off"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_today_label"
            tools:visibility="visible" />

        <!-- Barrier based only on variable content (card OR no-training message), not the section label -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/dashboard_home_below_today_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="dashboard_home_today_card,dashboard_home_no_training_message" />

        <!-- My Requests section -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_my_requests_label"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/my_requests_section_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_below_today_barrier" />

        <!-- Exactly one of empty vs list is visible; default empty so section never collapses -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dashboard_home_my_requests_empty"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="@string/my_requests_empty"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_my_requests_label"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dashboard_home_my_requests_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_my_requests_label"
            tools:listitem="@layout/item_my_join_request"
            tools:visibility="visible" />

        <!-- Barrier based only on dynamic content (empty message OR list), not the section label -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/dashboard_home_below_my_requests_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="dashboard_home_my_requests_empty,dashboard_home_my_requests_list" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dashboard_home_btn_teams_list"
            style="@style/Widget.CarpoolKids.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/btn_teams_list"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_below_my_requests_barrier" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dashboard_home_btn_create_join"
            style="@style/Widget.CarpoolKids.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/btn_create_join_group"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_btn_teams_list" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dashboard_home_btn_leave_carpool"
            style="@style/Widget.CarpoolKids.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/leave_carpool"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_btn_create_join" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/dashboard_home_below_leave_or_create_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="dashboard_home_btn_leave_carpool,dashboard_home_btn_create_join" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dashboard_home_btn_sign_out"
            style="@style/Widget.CarpoolKids.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/sign_out"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_home_below_leave_or_create_barrier" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
