<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_section">

        <!-- Carpool: <group name> or "No active group" -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/group_hub_header_carpool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Dashboard.Title"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Carpool: My Team" />

        <!-- Shown only when no active group -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/group_hub_header_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            style="@style/TextAppearance.Dashboard.SectionLabel"
            android:text="@string/group_hub_header_subtitle"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/group_hub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/group_hub_title"
            style="@style/TextAppearance.Dashboard.Title" />

        <androidx.cardview.widget.CardView
            android:id="@+id/group_hub_card_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/dashboard_card_background">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/group_hub_label_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_lg"
                android:text="@string/group_hub_details"
                style="@style/TextAppearance.Dashboard.Title" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/group_hub_card_invite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/dashboard_card_background">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/group_hub_label_invite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_lg"
                android:text="@string/group_hub_invite"
                style="@style/TextAppearance.Dashboard.Title" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/group_hub_card_join_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/dashboard_card_background">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/group_hub_label_join_requests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_lg"
                style="@style/TextAppearance.Dashboard.Title"
                tools:text="Join requests (0)" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/group_hub_card_blocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/dashboard_card_background">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/group_hub_label_blocked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_lg"
                android:text="@string/group_hub_blocked_users"
                style="@style/TextAppearance.Dashboard.Title" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
