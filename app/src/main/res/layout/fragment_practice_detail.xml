<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true"
    android:padding="@dimen/spacing_section">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/practice_detail_title"
            style="@style/TextAppearance.Dashboard.Title" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_canceled_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/practice_canceled_banner"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/status_pending_orange"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_day_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/practice_detail_day"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/dashboard_text_secondary" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_title_size"
            android:textColor="@color/dashboard_text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Tue" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/practice_detail_date"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/dashboard_text_secondary" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_title_size"
            android:textColor="@color/dashboard_text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="11 Feb" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_start_time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/practice_detail_start_time"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/dashboard_text_secondary" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/practice_detail_start_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_min_height"
            android:padding="@dimen/spacing_lg"
            android:background="@color/dashboard_card_background"
            android:inputType="time"
            android:textSize="@dimen/text_title_size"
            android:textColor="@color/dashboard_text_primary"
            android:textColorHint="@color/dashboard_text_secondary"
            android:maxLines="1"
            android:hint="@string/practice_detail_hint_start_time"
            android:imeOptions="actionNext" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_end_time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/practice_detail_end_time"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/dashboard_text_secondary" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/practice_detail_end_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_min_height"
            android:padding="@dimen/spacing_lg"
            android:background="@color/dashboard_card_background"
            android:inputType="time"
            android:textSize="@dimen/text_title_size"
            android:textColor="@color/dashboard_text_primary"
            android:textColorHint="@color/dashboard_text_secondary"
            android:maxLines="1"
            android:hint="@string/practice_detail_hint_end_time"
            android:imeOptions="actionNext" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/practice_detail_location_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/practice_detail_location"
            android:textSize="@dimen/text_section_label_size"
            android:textColor="@color/dashboard_text_secondary" />

        <!-- Read-only: the location string is set by the map picker (reverse-geocoded) — no manual typing. -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/practice_detail_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_min_height"
            android:padding="@dimen/spacing_lg"
            android:background="@color/dashboard_card_background"
            android:cursorVisible="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:inputType="none"
            android:longClickable="false"
            android:textSize="@dimen/text_title_size"
            android:textColor="@color/dashboard_text_primary"
            android:textColorHint="@color/dashboard_text_secondary"
            android:textDirection="ltr"
            android:maxLines="2"
            android:ellipsize="end"
            android:hint="@string/practice_detail_hint_location" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/practice_detail_set_location_on_map"
            style="@style/Widget.CarpoolKids.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/practice_detail_set_location_on_map"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/practice_detail_transport_card"
            style="@style/Widget.CarpoolKids.CardView.Dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_transport_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/practice_detail_transportation_title"
                    android:textSize="@dimen/text_section_label_size"
                    android:textColor="@color/dashboard_text_primary"
                    android:textStyle="bold" />

                <!-- Phase 3: child rider self-management. Hidden for parents and for canceled practices. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practice_detail_join_button"
                    style="@style/Widget.CarpoolKids.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/practice_join_button"
                    android:textSize="@dimen/text_button_compact"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_join_pending_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/practice_join_already_pending"
                    android:textColor="@color/status_pending_orange"
                    android:textSize="@dimen/text_caption_size"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Riders list: visible to anyone when at least one child is in the carpool. -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_riders_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="@dimen/text_caption_size"
                    android:visibility="gone"
                    tools:text="Riders (3)"
                    tools:visibility="visible" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_riders_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textColor="@color/dashboard_text_primary"
                    android:textDirection="ltr"
                    android:textSize="@dimen/text_section_label_size"
                    android:visibility="gone"
                    tools:text="Daniel, Maya, Yossi"
                    tools:visibility="visible" />

                <!-- TO practice section -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_to_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/practice_detail_to_practice"
                    android:textSize="@dimen/text_caption_size"
                    android:textColor="@color/dashboard_text_secondary" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_driver_to_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_section_label_size"
                    android:textColor="@color/dashboard_text_primary"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Rachel Israeli" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practice_detail_request_to"
                        style="@style/Widget.CarpoolKids.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:textSize="@dimen/text_button_compact"
                        android:text="@string/carpool_request"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practice_detail_ill_take_to"
                        style="@style/Widget.CarpoolKids.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:textSize="@dimen/text_button_compact"
                        android:text="@string/drive_request_ill_take_to"
                        android:visibility="gone" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practice_detail_cancel_to"
                    style="@style/Widget.CarpoolKids.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_button_compact"
                    android:text="@string/drive_request_cancel_drive"
                    android:visibility="gone" />

                <!-- FROM practice section -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_from_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/practice_detail_from_practice"
                    android:textSize="@dimen/text_caption_size"
                    android:textColor="@color/dashboard_text_secondary" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/practice_detail_driver_from_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_section_label_size"
                    android:textColor="@color/dashboard_text_primary"
                    android:textDirection="ltr"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Rachel Israeli" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practice_detail_request_from"
                        style="@style/Widget.CarpoolKids.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:textSize="@dimen/text_button_compact"
                        android:text="@string/carpool_request"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practice_detail_ill_take_from"
                        style="@style/Widget.CarpoolKids.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:textSize="@dimen/text_button_compact"
                        android:text="@string/drive_request_ill_take_from"
                        android:visibility="gone" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practice_detail_cancel_from"
                    style="@style/Widget.CarpoolKids.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_button_compact"
                    android:text="@string/drive_request_cancel_drive"
                    android:visibility="gone" />

                <!-- Phase 6 — open the shared route screen. Visible to every group member when a
                     driver is assigned for that direction; route generation itself lives in the
                     route screen so non-drivers can still open it and see "not generated yet". -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practice_detail_view_pickup_route"
                    style="@style/Widget.CarpoolKids.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:textSize="@dimen/text_button_compact"
                    android:text="@string/route_view_pickup"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practice_detail_view_dropoff_route"
                    style="@style/Widget.CarpoolKids.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textSize="@dimen/text_button_compact"
                    android:text="@string/route_view_dropoff"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/practice_detail_cancel_practice"
            style="@style/Widget.CarpoolKids.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section"
            android:text="@string/practice_cancel_practice"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/practice_detail_save"
            style="@style/Widget.CarpoolKids.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/btn_save" />
    </LinearLayout>
</ScrollView>
