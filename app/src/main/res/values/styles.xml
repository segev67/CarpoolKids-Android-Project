<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dashboard section label -->
    <style name="TextAppearance.Dashboard.SectionLabel" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_section_label_size</item>
        <item name="android:textColor">@color/dashboard_text_secondary</item>
    </style>

    <!-- Dashboard title (group name) -->
    <style name="TextAppearance.Dashboard.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_title_size</item>
        <item name="android:textColor">@color/dashboard_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Session card: rounded, elevated (parent Elevated removed in Material 1.11+) -->
    <style name="Widget.CarpoolKids.CardView.Dashboard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/dashboard_card_background</item>
    </style>

    <!-- Unified button style for all buttons in the project -->
    <style name="Widget.CarpoolKids.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/button_primary_blue</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
    </style>
    <style name="Widget.CarpoolKids.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/button_primary_blue</item>
        <item name="android:textColor">@color/button_primary_blue</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
    </style>

    <!-- Join requests card: three equal-width actions; same text size + fixed height (no per-button autosize). -->
    <style name="Widget.CarpoolKids.Button.JoinRequestAction" parent="Widget.CarpoolKids.Button">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:maxLines">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/join_request_action_text_size</item>
    </style>

    <!-- Home: team card title (kept distinct from Dashboard.Title; uses Subtitle1 parent for different letter-spacing) -->
    <style name="TextAppearance.Home.TeamName" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">@dimen/text_title_size</item>
        <item name="android:textColor">@color/dashboard_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Drive-request picker dialog: Applied via AlertDialog.Builder(ctx, R.style.ThemeOverlay_CarpoolKids_PickerDialog)
         so it's scoped to that single dialog without touching the app theme. -->
    <style name="ThemeOverlay.CarpoolKids.PickerDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="textAppearanceListItem">@style/TextAppearance.CarpoolKids.PickerItem</item>
    </style>
    <style name="TextAppearance.CarpoolKids.PickerItem" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">14sp</item>
    </style>
</resources>
