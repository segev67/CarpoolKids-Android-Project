rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can write only their own document. Any authenticated user can read
    // (for Join Requests / Blocked Users email display)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Groups: read/create for any authenticated user. Update for members.
    // Delete only when the user is the last remaining member (delete carpool flow).
    match /groups/{groupId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.memberIds
        && resource.data.memberIds.size() == 1;
    }

    // Join requests
    match /join_requests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.requesterUid == request.auth.uid
        && request.resource.data.status == "PENDING";

      allow read: if request.auth != null && (
        resource.data.requesterUid == request.auth.uid
        || request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds
      );

      allow update: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;

      allow delete: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;
    }

    // Practices (Schedule)
    match /practices/{practiceId} {
      allow read, update, delete: if request.auth != null
        && resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;
      allow create: if request.auth != null
        && request.resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds;
    }

    // Drive requests: group members read/create; parents update any; children update own requests;
    // members may delete (cleanup when carpool is removed).
    match /drive_requests/{requestId} {
      allow read: if request.auth != null
        && resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;

      allow create: if request.auth != null
        && request.resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds;

      allow update: if request.auth != null
        && resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PARENT'
          || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'CHILD'
            && resource.data.requesterUid == request.auth.uid
          )
        );

      allow delete: if request.auth != null
        && resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;
    }

    // Parent/child link codes (short-lived codes tied to a group)
    match /link_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds;
      allow delete: if request.auth != null
        && resource.data.groupId != null
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds;
    }
  }
}